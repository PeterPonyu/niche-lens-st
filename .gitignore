.omc/

# Local real-data caches; keep data/cards tracked.
data/raw/
data/processed/
!data/cards/

# Generated outputs
results/*
!results/README.md
manuscript/*.aux
manuscript/*.bbl
manuscript/*.blg
manuscript/*.log
manuscript/*.out
manuscript/*.pdf
