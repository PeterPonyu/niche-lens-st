# Python/cache + build artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# Local environments and baseline checkouts
.venv/
.env
.external_baselines/
baseline_repos/*
