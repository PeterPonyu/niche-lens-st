# Python/cache + build artifacts (recursive — caches can appear in subdirs)
**/__pycache__/
*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
*.egg-info/
build/
dist/

# Local environments and baseline checkouts
.venv/
.env
.external_baselines/
baseline_repos/*
!baseline_repos/README.md

# OMC runtime state (recursive — created in subdirs during local testing/audits)
**/.omc/

# Editor / OS files
.vscode/
.idea/
.DS_Store
*.swp

# Dataset cache (written by scripts/data/fetch_datasets.py) — only data/cards/ is tracked
data/raw/
data/processed/
data/cache/

# Dataset cache (written by scripts/data/fetch_datasets.py) — only data/cards/ is tracked
data/raw/
data/processed/
data/cache/

# Generated outputs
results/*
!results/README.md
!results/paper_metrics/
manuscript/*.aux
manuscript/*.bbl
manuscript/*.blg
manuscript/*.log
manuscript/*.out
manuscript/*.pdf
